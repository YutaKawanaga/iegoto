{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @iegoto/db run generate && pnpm --filter @iegoto/db exec prisma migrate deploy && pnpm --filter @iegoto/web run build && node scripts/build-vercel-function.mjs",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/trpc/:path*", "destination": "/api" },
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/jobs/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/((?!api|assets|favicon).*)", "destination": "/index.html" }
  ]
}
