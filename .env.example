# ローカル開発用 (.env にコピーして使う。.env はコミットしない)

# --- DB (packages/db) ---
# ローカル: compose.yml の postgres / 本番: Neon の pooler 接続文字列 (Vercel 環境変数で設定)
DATABASE_URL=postgresql://iegoto:iegoto@localhost:5432/iegoto

# --- 認証 (apps/api) ---
# Google OAuth クライアント (GCP Console で作成。ローカルは redirect URI に
# http://localhost:8000/auth/google/callback を登録)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# アプリのオリジン (ローカルは Vite dev サーバ)
APP_ORIGIN=http://localhost:7475
# API 自身のオリジン (OAuth callback 用。ローカルは Hono サーバ)
API_ORIGIN=http://localhost:8000
# 開発用ログインバイパス (1 で有効。Google 認証なしで /auth/dev?email=... からログインできる。
# 本番では絶対に設定しないこと)
AUTH_DEV_BYPASS=1

# --- jobs (apps/api。フェーズ3以降) ---
# Cloud Scheduler からのジョブ呼び出し認証用シークレット
CRON_SECRET=
